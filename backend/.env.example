# Database connection URL (direct connection string to PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=no-verify"

# Master symmetric key (AES-256-GCM) - MUST be at least 32 characters long
ENCRYPTION_KEY="your_super_secret_master_key_32_bytes_long"

# Port to run the NestJS server on (defaults to 5000)
PORT=5000

# URL of the Next.js frontend (used for CORS configuration)
FRONTEND_URL="http://localhost:3000"
